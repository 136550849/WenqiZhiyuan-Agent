# 电子书库模块环境配置示例
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ===========================================
# Tushare API 配置（可选）
# 获取 Token: https://tushare.pro/user/token
# ===========================================
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_BASE_URL=https://api.tushare.pro

# ===========================================
# 飞书 Bitable 配置（可选）
# 获取 API Token: https://open.feishu.cn/app
# ===========================================
FEISHU_APP_TOKEN=your_feishu_app_token_here
FEISHU_API_TOKEN=your_feishu_api_token_here

# ===========================================
# Calibre 配置（可选）
# 用于 AZW3 格式元数据提取
# ===========================================
CALIBRE_PATH=C:/Program Files/Calibre/calibre.exe

# ===========================================
# 缓存配置
# ===========================================
CACHE_DIR=./cache
CACHE_EXPIRY_HOURS=24

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=./logs/ebook_library.log
